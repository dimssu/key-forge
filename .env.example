# Public site URL — used for canonical URLs, sitemap, OG image absolute paths, share links.
# Defaults to https://keyforge.dimssu.com when unset.
NEXT_PUBLIC_SITE_URL=https://keyforge.dimssu.com

# Optional: enables the 90-day rotation reminder feature.
# When unset, the reminder UI is hidden everywhere on the site.
RESEND_API_KEY=

# Optional: from-address for reminder emails. Defaults to "no-reply@keyforge.dimssu.com".
REMINDER_FROM_EMAIL=no-reply@keyforge.dimssu.com

# Required for signed share + reminder JWT links. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When unset, share + reminder routes return 503.
KEYFORGE_SIGNING_SECRET=

# Optional: per-IP rate limit window (requests per minute) on /api/proxy/*. Defaults to 30.
KEYFORGE_RATE_LIMIT_PER_MINUTE=30
